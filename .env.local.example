# ─── Frontend (apps/frontend) ─────────────────────────────────────────────
# Optional — app falls back to mock data if these are not set.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Backend (apps/backend) ───────────────────────────────────────────────
# Required for the MCP server to read/write real data. Service-role key
# bypasses RLS — keep secret. Backend falls back to mock reads if missing.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PORT=3001
